<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <!-- Get all products -->
    <route url="/V1/nam/products" method="GET">
        <service class="Nam\ProductApi\Api\ProductRepositoryInterface" method="getProducts"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <!-- Get products by category -->
    <route url="/V1/nam/products/category/:categoryId" method="GET">
        <service class="Nam\ProductApi\Api\ProductRepositoryInterface" method="getProductsByCategory"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
</routes>
