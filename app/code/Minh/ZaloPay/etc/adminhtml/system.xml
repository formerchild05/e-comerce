<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="minh_zalopay" translate="label" type="text" sortOrder="16" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>ZaloPay</label>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Title</label>
                </field>
                <field id="app_id" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1">
                    <label>App ID</label>
                </field>
                <field id="key1" translate="label" type="obscure" sortOrder="40" showInDefault="1" showInWebsite="1">
                    <label>Key 1</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="key2" translate="label" type="obscure" sortOrder="50" showInDefault="1" showInWebsite="1">
                    <label>Key 2 / Callback Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="create_order_url" translate="label" type="text" sortOrder="60" showInDefault="1" showInWebsite="1">
                    <label>Create Order URL</label>
                </field>
                <field id="query_order_url" translate="label" type="text" sortOrder="70" showInDefault="1" showInWebsite="1">
                    <label>Query Order URL</label>
                </field>
                <field id="callback_url_override" translate="label comment" type="text" sortOrder="80" showInDefault="1" showInWebsite="1">
                    <label>Callback URL Override</label>
                    <comment>Use a public HTTPS URL when testing automatic callbacks from ZaloPay.</comment>
                </field>
                <field id="redirect_url_override" translate="label comment" type="text" sortOrder="90" showInDefault="1" showInWebsite="1">
                    <label>Redirect URL Override</label>
                    <comment>Use a public HTTPS URL if the browser should return through a public domain.</comment>
                </field>
                <field id="preferred_payment_method" translate="label comment" type="select" sortOrder="100" showInDefault="1" showInWebsite="1">
                    <label>Preferred Payment Method</label>
                    <comment>Leave as All to show all ZaloPay Gateway payment methods.</comment>
                    <source_model>Minh\ZaloPay\Model\Config\Source\PreferredPaymentMethod</source_model>
                </field>
                <field id="order_status" translate="label" type="select" sortOrder="110" showInDefault="1" showInWebsite="1">
                    <label>New Order Status</label>
                    <source_model>Magento\Sales\Model\Config\Source\Order\Status\NewStatus</source_model>
                </field>
                <field id="debug" translate="label" type="select" sortOrder="120" showInDefault="1" showInWebsite="1">
                    <label>Debug</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="allowspecific" translate="label" type="allowspecific" sortOrder="130" showInDefault="1" showInWebsite="1">
                    <label>Payment from Applicable Countries</label>
                    <source_model>Magento\Payment\Model\Config\Source\Allspecificcountries</source_model>
                </field>
                <field id="specificcountry" translate="label" type="multiselect" sortOrder="140" showInDefault="1" showInWebsite="1">
                    <label>Payment from Specific Countries</label>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                    <can_be_empty>1</can_be_empty>
                </field>
                <field id="min_order_total" translate="label" type="text" sortOrder="150" showInDefault="1" showInWebsite="1">
                    <label>Minimum Order Total</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="max_order_total" translate="label" type="text" sortOrder="160" showInDefault="1" showInWebsite="1">
                    <label>Maximum Order Total</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="sort_order" translate="label" type="text" sortOrder="170" showInDefault="1" showInWebsite="1">
                    <label>Sort Order</label>
                    <validate>validate-number</validate>
                </field>
            </group>
        </section>
    </system>
</config>
